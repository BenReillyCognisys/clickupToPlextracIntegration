PORT=4000

# ── ClickUp ──────────────────────────────────────────────────────────────────
# Personal API token (ClickUp → Settings → Apps → API Token)
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxx

# Workspace/team ID (visible in the URL: app.clickup.com/{team_id}/...)
CLICKUP_TEAM_ID=

# Space ID for "Penetration Testing" — find it by running: node scripts/list-spaces.js
CLICKUP_SPACE_ID=

# Webhook signing secret — set this after running: node scripts/register-webhook.js
CLICKUP_WEBHOOK_SECRET=

# Public URL of this server (no trailing slash)
WEBHOOK_URL=https://api.break.services

# ── Plextrac ─────────────────────────────────────────────────────────────────
# Plextrac instance hostname (no https://)
PLEXTRAC_INSTANCE=cognisys.plextrac.com

# Service-account credentials — used to obtain a JWT on startup (auto-refreshed)
PLEXTRAC_USERNAME=
PLEXTRAC_PASSWORD=

# Template and layout names to use when creating reports (must match exactly in Plextrac)
PLEXTRAC_REPORT_TEMPLATE=Cognisys Web Application Black Box
PLEXTRAC_FINDINGS_LAYOUT=Pentest Cognisys

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Connection string from Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=clickup_plextrac

# ── Plextrac → ClickUp status mapping ────────────────────────────────────────
# Plextrac webhook secret (set when configuring the webhook in Plextrac)
PLEXTRAC_WEBHOOK_SECRET=

# ClickUp status to set when a Plextrac report moves to "Ready For Review"
CLICKUP_STATUS_QA=QA / Reviewing

# ClickUp status to set when a Plextrac report is Published
CLICKUP_STATUS_COMPLETE=Completed

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Bot token (xoxb-...) with the chat:write scope, used to post the threaded
# first-round-QA messages (incoming webhooks can't thread). The bot must be a
# member of the #pt-first-round-qa channel.
SLACK_BOT_TOKEN=
# Channel id for #pt-first-round-qa (from the channel URL: .../archives/<id>)
SLACK_FIRST_ROUND_QA_CHANNEL=C0B9D6487HR

# ── AI QA Review (Plextrac "ready for QA" webhook) ────────────────────────────
# Claude API key — get one at console.anthropic.com. NOTE: a Claude Pro/Max
# subscription does NOT work here; server-side calls require a billed API key.
ANTHROPIC_API_KEY=sk-ant-...
# Model (default: claude-haiku-4-5 — cheapest; ~5x less than Opus). Raise to
# claude-sonnet-4-6 or claude-opus-4-8 only if you need higher edit quality.
#ANTHROPIC_MODEL=claude-haiku-4-5
# Cost controls for the AI checks:
#QA_AI_THINKING=false      # extended thinking off by default (thinking tokens bill as output)
#QA_AI_EFFORT=             # leave blank; only set on Opus/Sonnet (errors on Haiku)
#QA_AI_MAX_TOKENS=4000     # output cap per call

# The QA review runs from the existing /webhook/plextrac handler (no separate
# webhook needed). This is the report status that triggers it — it must match the
# status Plextrac sets when a report is ready for QA.
PLEXTRAC_QA_STATUS=Ready For Review

# Dedicated Slack channel for QA change reports (falls back to SLACK_WEBHOOK_URL)
QA_SLACK_WEBHOOK_URL=

# Append-only audit log file (every change is written here as well as to Slack)
LOG_FILE=./logs/qa-review.log

# Per-check toggles — set to "false" to disable an individual check
#QA_CHECK_STRIP_FORMATTING=true   # NOTE: currently PAUSED in code (being redefined)
#QA_CHECK_CLIENT_NAME=true
#QA_CHECK_DEJARGON=true
#QA_CHECK_SENTENCES=true

# Safety cap on how many findings to process per report
#QA_MAX_FINDINGS=200

# Organisation names the client-name check must NEVER change (the testing
# provider is not the client). Comma-separated; defaults to the Cognisys variants.
#QA_PROTECTED_NAMES=Cognisys Group Limited,Cognisys Group,Cognisys

# Executive-summary section names to SKIP entirely (no AI checks). These are
# templated/boilerplate sections, not narrative. Matching is case-insensitive and
# substring-based against the section label/title. Comma-separated; defaults to
# Methodology and Issue Matrix.
#QA_EXCLUDED_SECTIONS=Methodology,Issue Matrix

# ── Plextrac change tracking ──────────────────────────────────────────────────
# Toggles the report's `isTrackChanges` field on before edits and off afterwards
# (via the report update endpoint). ON by default — set to false to opt out (the
# internal audit log in LOG_FILE + Slack records every change regardless).
#PLEXTRAC_CHANGE_TRACKING_ENABLED=true
