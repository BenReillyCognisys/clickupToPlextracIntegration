PORT=4000

# ── ClickUp ──────────────────────────────────────────────────────────────────
# Personal API token (ClickUp → Settings → Apps → API Token)
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxx

# Workspace/team ID (visible in the URL: app.clickup.com/{team_id}/...)
CLICKUP_TEAM_ID=

# Space ID for "Penetration Testing" — find it by running: node scripts/list-spaces.js
CLICKUP_SPACE_ID=

# Webhook signing secret — set this after running: node scripts/register-webhook.js
CLICKUP_WEBHOOK_SECRET=

# Public URL of this server (no trailing slash)
WEBHOOK_URL=https://api.break.services

# ── Scheduling (/schedule/pentest) ───────────────────────────────────────────
# Backs the POST /schedule/pentest endpoint, which creates a ClickUp engagement
# task from a chosen consultant + date range. A background job refreshes the
# consultant-availability and service-types cache every CLICKUP_REFRESH_INTERVAL_MS.

# Shared secret required in the X-API-Key header on the scheduling endpoints
AVAILABILITY_API_KEY=

# Comma-separated CORS allowlist for the browser-facing scheduling endpoints
# (GET /availability/pentest, POST /schedule/pentest). Leave blank to reflect
# any origin (matches the sfe-portal's previous behaviour); set to the exact
# frontend origin(s) to lock it down, e.g. https://app.example.com
SCHEDULING_ALLOWED_ORIGINS=

# Team view whose sidebar lists the bookable consultants (the "roster")
CLICKUP_VIEW_ID=

# ClickUp Doc holding the Service Type → Independent consultants table
CLICKUP_SERVICE_TYPES_DOC_ID=
CLICKUP_SERVICE_TYPES_PAGE_ID=

# Internal-audit roster (GET /availability/internalaudit) = the people pinned in
# the sidebar of this ClickUp view — same mechanism as CLICKUP_VIEW_ID above, just
# a different view. No service-type/skill filtering: availability is searched purely
# on day count across those people. This is the view id from the URL
# app.clickup.com/{team}/v/wl/{viewId}. Defaults to the known view id if unset.
#CLICKUP_INTERNAL_AUDIT_VIEW_ID=6-901507566408-18

# List that new engagement tasks are created in, and its numeric custom fields
CLICKUP_ENGAGEMENT_LIST_ID=
CLICKUP_DAYS_FIELD_NAME=Days Balance
CLICKUP_REVENUE_FIELD_NAME=R

# Custom field(s) holding a task's effort in days (e.g. 0.5 = half day), used by
# GET /availability/freeblackbox to compute half-day gaps. Comma-separated, tried
# in order; the first one present on a task wins. Defaults to "Days, Days Balance".
#CLICKUP_LOAD_FIELD_NAMES=Days, Days Balance
# Optional status to set on newly created engagement tasks
#CLICKUP_DEFAULT_STATUS=

# Optional cache tuning (defaults shown)
#CLICKUP_TIMEZONE=Europe/London
#CLICKUP_WEEKS=4
#CLICKUP_INCLUDE_CLOSED=false
#CLICKUP_REFRESH_INTERVAL_MS=120000
# JSON {id:name} fallback roster used only if the view sidebar has no assignees
#CLICKUP_ROSTER_FALLBACK={}

# ── Plextrac ─────────────────────────────────────────────────────────────────
# Plextrac instance hostname (no https://)
PLEXTRAC_INSTANCE=cognisys.plextrac.com

# Service-account credentials — used to obtain a JWT on startup (auto-refreshed)
PLEXTRAC_USERNAME=
PLEXTRAC_PASSWORD=

# Template and layout names to use when creating reports (must match exactly in Plextrac)
PLEXTRAC_REPORT_TEMPLATE=Cognisys Web Application Black Box
PLEXTRAC_FINDINGS_LAYOUT=Pentest Cognisys

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Connection string from Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=clickup_plextrac

# ── Plextrac → ClickUp status mapping ────────────────────────────────────────
# Plextrac webhook secret (set when configuring the webhook in Plextrac)
PLEXTRAC_WEBHOOK_SECRET=

# ClickUp status to set when a Plextrac report moves to "Ready For Review"
CLICKUP_STATUS_QA=QA / Reviewing

# ClickUp status to set when a Plextrac report is Published
CLICKUP_STATUS_COMPLETE=Completed

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Bot token (xoxb-...) with the chat:write scope, used to post the threaded
# first-round-QA messages (incoming webhooks can't thread). The bot must be a
# member of the #pt-first-round-qa channel.
SLACK_BOT_TOKEN=
# Channel id for #pt-first-round-qa (from the channel URL: .../archives/<id>)
SLACK_FIRST_ROUND_QA_CHANNEL=C0B9D6487HR

# ── Daily auth-form check (Penetration Test space) ────────────────────────────
# Runs daily at 14:00 and can be triggered manually via POST /jobs/auth-form-check.
# Scans the Penetration Test space (CLICKUP_SPACE_ID) for tasks with the
# "Pre Recs Received?" checkbox ticked but "Tester OKd Pre-Recs" NOT yet ticked,
# at least one assignee, and a start date within the next AUTH_FORM_WINDOW_DAYS
# days (default 7 ≈ the coming 5 business days). It then posts ONE message to the
# qa-chat channel @-mentioning the assigned users, grouped under their start date.
#
# Every 5 minutes after that, a reconcile re-scans the space and strikes through
# any listed task that's since been actioned (Tester OKd Pre-Recs ticked, or the
# task closed), editing the same message in place. Trigger it manually via POST
# /jobs/auth-form-reconcile. Editing the message needs the bot's `chat:write` scope.
#
# Channel the bot posts to (it must be a member). Use the channel ID, not the
# name — chat.postMessage returns channel_not_found for names like "#qa-chat-".
# Get the ID from the channel's "About" popup or its URL (.../archives/C0123ABCD).
# Mentions also require the bot token to have the `users:read.email` scope (to
# resolve ClickUp emails → Slack ids).
SLACK_AUTH_FORM_CHANNEL=C0123ABCD
# Optional overrides for the schedules (standard cron), timezone, and how many days
# ahead a job's start date may be to get chased (default 7).
#AUTH_FORM_CHECK_CRON=0 14 * * *
#AUTH_FORM_RECONCILE_CRON=*/5 * * * *
#AUTH_FORM_CHECK_TZ=Europe/London
#AUTH_FORM_WINDOW_DAYS=7

# ── Weekly reports-due check (Pentesting space) ───────────────────────────────
# Scans the Pentesting space (CLICKUP_SPACE_ID) and, for each task, computes the
# report deadline as the task's due date + REPORTS_DUE_SLA_DAYS business days (3).
# Posts ONE Slack message listing deadlines missed (within the last
# REPORTS_DUE_MISSED_LOOKBACK_DAYS days) and those landing Mon–Fri this week,
# grouped by day. Trigger manually with POST /jobs/reports-due.
#
# Channel the report is posted to (the bot must be a member). Channel ID, not name.
SLACK_REPORTS_DUE_CHANNEL=C091H6MLS6A
# Runs Mondays at 06:00 by default. Override the schedule here, or set it blank
# (REPORTS_DUE_CRON=) to disable the cron and run manually only.
#REPORTS_DUE_CRON=0 6 * * 1
#REPORTS_DUE_TZ=Europe/London
#REPORTS_DUE_SLA_DAYS=3
#REPORTS_DUE_MISSED_LOOKBACK_DAYS=14
#REPORTS_DUE_SHOW_MISSED_SLA=true

# ── AI QA Review (Plextrac "ready for QA" webhook) ────────────────────────────
# Claude API key — get one at console.anthropic.com. NOTE: a Claude Pro/Max
# subscription does NOT work here; server-side calls require a billed API key.
ANTHROPIC_API_KEY=sk-ant-...
# Model (default: claude-haiku-4-5 — cheapest; ~5x less than Opus). Raise to
# claude-sonnet-4-6 or claude-opus-4-8 only if you need higher edit quality.
#ANTHROPIC_MODEL=claude-haiku-4-5
# Cost controls for the AI checks:
#QA_AI_THINKING=false      # extended thinking off by default (thinking tokens bill as output)
#QA_AI_EFFORT=             # leave blank; only set on Opus/Sonnet (errors on Haiku)
#QA_AI_MAX_TOKENS=4000     # output cap per call

# The QA review runs from the existing /webhook/plextrac handler (no separate
# webhook needed). This is the report status that triggers it — it must match the
# status Plextrac sets when a report is ready for QA.
PLEXTRAC_QA_STATUS=Ready For Review

# Dedicated Slack channel for QA change reports (falls back to SLACK_WEBHOOK_URL)
QA_SLACK_WEBHOOK_URL=

# Append-only audit log file (every change is written here as well as to Slack)
LOG_FILE=./logs/qa-review.log

# Per-check toggles — set to "false" to disable an individual check
#QA_CHECK_STRIP_FORMATTING=true   # NOTE: currently PAUSED in code (being redefined)
#QA_CHECK_CLIENT_NAME=true
#QA_CHECK_DEJARGON=true
#QA_CHECK_SENTENCES=true

# Safety cap on how many findings to process per report
#QA_MAX_FINDINGS=200

# Organisation names the client-name check must NEVER change (the testing
# provider is not the client). Comma-separated; defaults to the Cognisys variants.
#QA_PROTECTED_NAMES=Cognisys Group Limited,Cognisys Group,Cognisys

# Executive-summary section names that get a REDUCED review: the client-name
# check still runs (the client name must be right everywhere) but de-jargon and
# incomplete-sentence checks are skipped. These are templated/boilerplate sections,
# not narrative. Matching is case-insensitive and substring-based against the
# section label/title. Comma-separated; defaults to Methodology, Issue Matrix and
# Limitations.
#QA_EXCLUDED_SECTIONS=Methodology,Issue Matrix,Limitations

# ── Plextrac change tracking ──────────────────────────────────────────────────
# Toggles the report's `isTrackChanges` field on before edits and off afterwards
# (via the report update endpoint). ON by default — set to false to opt out (the
# internal audit log in LOG_FILE + Slack records every change regardless).
#PLEXTRAC_CHANGE_TRACKING_ENABLED=true
