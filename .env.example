PORT=4000

# ── ClickUp ──────────────────────────────────────────────────────────────────
# Personal API token (ClickUp → Settings → Apps → API Token)
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxx

# Workspace/team ID (visible in the URL: app.clickup.com/{team_id}/...)
CLICKUP_TEAM_ID=

# Space ID for "Penetration Testing" — find it by running: node scripts/list-spaces.js
CLICKUP_SPACE_ID=

# Webhook signing secret — set this after running: node scripts/register-webhook.js
CLICKUP_WEBHOOK_SECRET=

# Public URL of this server (no trailing slash)
WEBHOOK_URL=https://api.break.services

# ── Plextrac ─────────────────────────────────────────────────────────────────
# Plextrac instance hostname (no https://)
PLEXTRAC_INSTANCE=cognisys.plextrac.com

# Service-account credentials — used to obtain a JWT on startup (auto-refreshed)
PLEXTRAC_USERNAME=
PLEXTRAC_PASSWORD=

# Template and layout names to use when creating reports (must match exactly in Plextrac)
PLEXTRAC_REPORT_TEMPLATE=Cognisys Web Application Black Box
PLEXTRAC_FINDINGS_LAYOUT=Pentest Cognisys

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Connection string from Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=clickup_plextrac

# ── Plextrac → ClickUp status mapping ────────────────────────────────────────
# Plextrac webhook secret (set when configuring the webhook in Plextrac)
PLEXTRAC_WEBHOOK_SECRET=

# ClickUp status to set when a Plextrac report moves to "Ready For Review"
CLICKUP_STATUS_QA=QA / Reviewing

# ClickUp status to set when a Plextrac report is Published
CLICKUP_STATUS_COMPLETE=Completed

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
